{
  "name": "astro-ultimate-tutorial",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "PUBLIC_ENV=preview astro dev",
    "build:production": "npm run generate:tag-analytics:check && PUBLIC_ENV=production astro build",
    "build:preview": "npm run generate:tag-analytics:check && PUBLIC_ENV=preview astro build",
    "start": "astro dev",
    "build": "npm run generate:tag-analytics && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:tag-analytics": "tsx src/scripts/generate-tag-analytics.ts",
    "generate:tag-analytics:check": "test -f public/tag-analytics.json && find public/tag-analytics.json -mmin -60 | grep -q . || npm run generate:tag-analytics",
    "storyblok:generate-types": "storyblok pull-components --space 332224 && storyblok generate-typescript-typedefs --sourceFilePaths ./components.332224.json --destinationFilePath ./src/types/component-types-sb.d.ts"
  },
  "devDependencies": {
    "@storyblok/astro": "^10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "astro": "^7.0.5",
    "dotenv": "^17.4.2",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "vite": "^8",
    "vite-plugin-mkcert": "^2.1.0"
  },
  "overrides": {
    "vite": "^8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@astrojs/node": "^11.0.1",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.23.0",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro-remote": "^0.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.23.0",
    "lucide-static": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storyblok-js-client": "^7.6.1",
    "storyblok-rich-text-astro-renderer": "^3.0.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
